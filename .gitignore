# ============================================================
# .gitignore — Portfolio Resume Project
# ============================================================

# --- Environment variables (NEVER commit secrets) ---
.env
.env.local
.env.*.local
.env.production

# --- Next.js ---
.next/
out/
build/
dist/

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Vercel ---
.vercel

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Logs ---
logs/
*.log

# --- Coverage ---
coverage/
.nyc_output/

# --- Cache ---
.cache/
.eslintcache
.stylelintcache

# --- Misc ---
*.pem
.turbo
